{
    "schema_version": "1.0",
    "name": "SpeedRunner",
    "description": "Speed/tickspeed focused game with probability, proc buffs, queue, gate, register, choice group, drain, and compound end condition.",
    "stacking_groups": {
        "tick": "multiplicative",
        "base": "multiplicative"
    },
    "nodes": [
        {"id": "energy", "type": "resource", "name": "Energy", "initial_value": 100.0},
        {"id": "data", "type": "resource", "name": "Data", "initial_value": 0.0},
        {"id": "tokens", "type": "resource", "name": "Tokens", "initial_value": 0.0},

        {"id": "scanner", "type": "generator", "name": "Scanner",
         "base_production": 5.0, "cost_base": 50.0, "cost_growth_rate": 1.1, "cycle_time": 1.0},
        {"id": "processor", "type": "generator", "name": "Processor",
         "base_production": 20.0, "cost_base": 500.0, "cost_growth_rate": 1.12, "cycle_time": 2.0},
        {"id": "compiler", "type": "generator", "name": "Compiler",
         "base_production": 100.0, "cost_base": 5000.0, "cost_growth_rate": 1.15, "cycle_time": 4.0},

        {"id": "tickspeed", "type": "tickspeed", "name": "Tickspeed"},

        {"id": "upg_tick_x1_5", "type": "upgrade", "name": "x1.5 Tickspeed",
         "upgrade_type": "multiplicative", "magnitude": 1.5, "cost": 1000.0,
         "target": "tickspeed", "stacking_group": "tick"},
        {"id": "upg_tick_x2", "type": "upgrade", "name": "x2 Tickspeed",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 10000.0,
         "target": "tickspeed", "stacking_group": "tick"},
        {"id": "upg_x2_scanner", "type": "upgrade", "name": "x2 Scanner",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 500.0,
         "target": "scanner", "stacking_group": "base"},
        {"id": "upg_x2_processor", "type": "upgrade", "name": "x2 Processor",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 5000.0,
         "target": "processor", "stacking_group": "base"},

        {"id": "crit_scanner", "type": "probability", "name": "Scanner Crit",
         "expected_value": 1.0, "crit_chance": 0.2, "crit_multiplier": 3.0},

        {"id": "speed_burst", "type": "buff", "name": "Speed Burst",
         "buff_type": "proc", "proc_chance": 0.1, "multiplier": 5.0,
         "target": "scanner"},
        {"id": "overclock", "type": "buff", "name": "Overclock",
         "buff_type": "timed", "duration": 5.0, "multiplier": 4.0,
         "cooldown": 20.0, "target": "processor"},

        {"id": "data_queue", "type": "queue", "name": "Data Queue",
         "delay": 3.0, "capacity": 100},
        {"id": "splitter", "type": "gate", "name": "Splitter",
         "mode": "probabilistic", "probabilities": [0.7, 0.3]},

        {"id": "speed_calc", "type": "register", "name": "Speed Calculator",
         "formula_expr": "owned_scanner * 0.1 + owned_processor * 0.05",
         "input_labels": [{"scanner": "Scanner count"}, {"processor": "Processor count"}]},

        {"id": "path_speed", "type": "upgrade", "name": "Speed Path",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 5000.0,
         "target": "tickspeed", "stacking_group": "tick"},
        {"id": "path_power", "type": "upgrade", "name": "Power Path",
         "upgrade_type": "multiplicative", "magnitude": 5.0, "cost": 5000.0,
         "target": "_all", "stacking_group": "base"},
        {"id": "choice_path", "type": "choice_group", "name": "Speed vs Power",
         "options": ["path_speed", "path_power"], "max_selections": 1,
         "respeccable": true, "respec_cost": 1000.0},

        {"id": "energy_drain", "type": "drain", "name": "Energy Drain", "rate": 2.0},

        {"id": "end_race", "type": "end_condition", "name": "Race Complete",
         "condition_type": "multi_threshold",
         "targets": [
             {"node_id": "data", "property": "current_value", "threshold": 1000000.0},
             {"node_id": "tokens", "property": "current_value", "threshold": 100.0}
         ],
         "logic": "and"}
    ],
    "edges": [
        {"id": "e_scanner_data", "source": "scanner", "target": "data", "edge_type": "production_target"},
        {"id": "e_processor_data", "source": "processor", "target": "data", "edge_type": "production_target"},
        {"id": "e_compiler_tokens", "source": "compiler", "target": "tokens", "edge_type": "production_target"},
        {"id": "e_drain_energy", "source": "energy_drain", "target": "energy", "edge_type": "consumption"},
        {"id": "e_crit_scanner", "source": "crit_scanner", "target": "scanner", "edge_type": "state_modifier",
         "formula": "1 + 0.2 * (3.0 - 1)",
         "target_property": "base_production", "modifier_mode": "multiply"},
        {"id": "e_choice_dep", "source": "choice_path", "target": "path_speed", "edge_type": "activator"}
    ]
}
