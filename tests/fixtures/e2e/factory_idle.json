{
    "schema_version": "1.0",
    "name": "FactoryIdle",
    "description": "Multi-resource converter economy. Converter chains, drains with conditions, timed/proc buffs, autobuyers, resource capacity.",
    "stacking_groups": {
        "base": "multiplicative",
        "milestones": "multiplicative"
    },
    "nodes": [
        {"id": "ore", "type": "resource", "name": "Ore",
         "initial_value": 100.0, "capacity": 5000.0, "overflow_behavior": "clamp"},
        {"id": "wood", "type": "resource", "name": "Wood", "initial_value": 50.0},
        {"id": "ingots", "type": "resource", "name": "Ingots",
         "initial_value": 0.0, "capacity": 2000.0},
        {"id": "steel", "type": "resource", "name": "Steel", "initial_value": 0.0},
        {"id": "tools", "type": "resource", "name": "Tools", "initial_value": 0.0},
        {"id": "gold", "type": "resource", "name": "Gold", "initial_value": 500.0},

        {"id": "miner", "type": "generator", "name": "Miner",
         "base_production": 3.0, "cost_base": 20.0, "cost_growth_rate": 1.12, "cycle_time": 1.0},
        {"id": "lumberjack", "type": "generator", "name": "Lumberjack",
         "base_production": 2.0, "cost_base": 25.0, "cost_growth_rate": 1.12, "cycle_time": 1.0},
        {"id": "smelter_worker", "type": "generator", "name": "Smelter Worker",
         "base_production": 1.0, "cost_base": 100.0, "cost_growth_rate": 1.15, "cycle_time": 2.0},
        {"id": "blacksmith", "type": "generator", "name": "Blacksmith",
         "base_production": 5.0, "cost_base": 500.0, "cost_growth_rate": 1.18, "cycle_time": 3.0},

        {"id": "forge", "type": "converter", "name": "Forge",
         "inputs": [{"resource": "ore", "amount": 3.0}],
         "outputs": [{"resource": "ingots", "amount": 1.0}],
         "recipe_type": "fixed"},
        {"id": "foundry", "type": "converter", "name": "Foundry",
         "inputs": [{"resource": "ingots", "amount": 2.0}, {"resource": "wood", "amount": 1.0}],
         "outputs": [{"resource": "steel", "amount": 1.0}],
         "recipe_type": "fixed", "pull_mode": "pull_all"},
        {"id": "workshop", "type": "converter", "name": "Workshop",
         "inputs": [{"resource": "steel", "amount": 1.0}, {"resource": "wood", "amount": 2.0}],
         "outputs": [{"resource": "tools", "amount": 3.0}],
         "recipe_type": "scaling", "conversion_limit": 10},

        {"id": "ore_decay", "type": "drain", "name": "Ore Decay",
         "rate": 1.0, "condition": "balance_ore > 4000"},
        {"id": "ingot_rust", "type": "drain", "name": "Ingot Rust", "rate": 0.5},

        {"id": "production_buff", "type": "buff", "name": "Production Surge",
         "buff_type": "timed", "duration": 15.0, "multiplier": 2.5,
         "cooldown": 45.0, "target": "miner"},
        {"id": "lucky_strike", "type": "buff", "name": "Lucky Strike",
         "buff_type": "proc", "proc_chance": 0.15, "multiplier": 3.0,
         "target": "smelter_worker"},

        {"id": "auto_miner", "type": "autobuyer", "name": "Auto Miner",
         "target": "miner", "interval": 10.0, "priority": 1, "bulk_amount": "1"},
        {"id": "auto_lumberjack", "type": "autobuyer", "name": "Auto Lumberjack",
         "target": "lumberjack", "interval": 10.0, "priority": 0, "bulk_amount": "1"},

        {"id": "upg_x2_miner", "type": "upgrade", "name": "x2 Miner",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 500.0,
         "target": "miner", "stacking_group": "base"},
        {"id": "upg_x2_smelter", "type": "upgrade", "name": "x2 Smelter",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 2000.0,
         "target": "smelter_worker", "stacking_group": "base"},
        {"id": "upg_x3_all", "type": "upgrade", "name": "x3 All",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 10000.0,
         "target": "_all", "stacking_group": "base"},

        {"id": "ach_50_miners", "type": "achievement", "name": "50 Miners",
         "condition_type": "single_threshold",
         "targets": [{"node_id": "miner", "property": "owned", "threshold": 50}],
         "bonus": {"type": "multiplicative", "magnitude": 1.5, "target": "miner", "stacking_group": "milestones"},
         "permanent": true},

        {"id": "end_1000_tools", "type": "end_condition", "name": "1000 Tools",
         "condition_type": "single_threshold",
         "targets": [{"node_id": "tools", "property": "current_value", "threshold": 1000.0}]}
    ],
    "edges": [
        {"id": "e_miner_ore", "source": "miner", "target": "ore", "edge_type": "production_target"},
        {"id": "e_lumber_wood", "source": "lumberjack", "target": "wood", "edge_type": "production_target"},
        {"id": "e_smelter_ingots", "source": "smelter_worker", "target": "ingots", "edge_type": "production_target"},
        {"id": "e_smith_gold", "source": "blacksmith", "target": "gold", "edge_type": "production_target"},
        {"id": "e_decay_ore", "source": "ore_decay", "target": "ore", "edge_type": "consumption"},
        {"id": "e_rust_ingots", "source": "ingot_rust", "target": "ingots", "edge_type": "consumption"}
    ]
}
