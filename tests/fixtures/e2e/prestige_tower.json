{
    "schema_version": "1.0",
    "name": "PrestigeTower",
    "description": "Deep prestige tree with 3 layers, sacrifice node, nested generator, synergies, state modifier edges testing all 3 modifier modes.",
    "stacking_groups": {
        "base": "multiplicative",
        "prestige_boost": "multiplicative",
        "milestones": "multiplicative"
    },
    "nodes": [
        {"id": "points", "type": "resource", "name": "Points", "initial_value": 0.0},
        {"id": "p1_currency", "type": "resource", "name": "Prestige I Points", "initial_value": 0.0},
        {"id": "p2_currency", "type": "resource", "name": "Prestige II Points", "initial_value": 0.0},
        {"id": "p3_currency", "type": "resource", "name": "Prestige III Points", "initial_value": 0.0},
        {"id": "sacrifice_pts", "type": "resource", "name": "Sacrifice Points", "initial_value": 0.0},

        {"id": "gen_t1", "type": "generator", "name": "Tier 1 Generator",
         "base_production": 1.0, "cost_base": 10.0, "cost_growth_rate": 1.1, "cycle_time": 1.0},
        {"id": "gen_t2", "type": "generator", "name": "Tier 2 Generator",
         "base_production": 10.0, "cost_base": 100.0, "cost_growth_rate": 1.12, "cycle_time": 2.0},
        {"id": "gen_t3", "type": "generator", "name": "Tier 3 Generator",
         "base_production": 100.0, "cost_base": 1000.0, "cost_growth_rate": 1.14, "cycle_time": 4.0},
        {"id": "gen_t4", "type": "generator", "name": "Tier 4 Generator",
         "base_production": 1000.0, "cost_base": 10000.0, "cost_growth_rate": 1.16, "cycle_time": 8.0},

        {"id": "nested_gen", "type": "nested_generator", "name": "Generator Factory",
         "target_generator": "gen_t1", "production_rate": 0.5,
         "cost_base": 5000.0, "cost_growth_rate": 1.2},

        {"id": "upg_x2_t1", "type": "upgrade", "name": "x2 Tier 1",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 500.0,
         "target": "gen_t1", "stacking_group": "base"},
        {"id": "upg_x2_t2", "type": "upgrade", "name": "x2 Tier 2",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 5000.0,
         "target": "gen_t2", "stacking_group": "base"},
        {"id": "upg_x3_all", "type": "upgrade", "name": "x3 All",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 100000.0,
         "target": "_all", "stacking_group": "base"},
        {"id": "upg_p1_x2", "type": "upgrade", "name": "Prestige I x2",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 50.0,
         "target": "_all", "stacking_group": "prestige_boost",
         "tags": ["prestige_1"]},

        {"id": "prestige_1", "type": "prestige_layer", "name": "Prestige I",
         "formula_expr": "floor(sqrt(lifetime_points))",
         "layer_index": 0,
         "currency_id": "p1_currency",
         "reset_scope": ["points", "gen_t1", "gen_t2", "gen_t3", "gen_t4",
                         "nested_gen", "upg_x2_t1", "upg_x2_t2", "upg_x3_all"],
         "persistence_scope": ["p1_currency", "p2_currency", "p3_currency",
                                "sacrifice_pts", "upg_p1_x2"],
         "bonus_type": "multiplicative"},
        {"id": "prestige_2", "type": "prestige_layer", "name": "Prestige II",
         "formula_expr": "floor(balance_p1_currency / 100)",
         "layer_index": 1,
         "parent_layer": "prestige_1",
         "currency_id": "p2_currency",
         "reset_scope": ["points", "gen_t1", "gen_t2", "gen_t3", "gen_t4",
                         "nested_gen", "upg_x2_t1", "upg_x2_t2", "upg_x3_all",
                         "p1_currency", "upg_p1_x2"],
         "persistence_scope": ["p2_currency", "p3_currency", "sacrifice_pts"],
         "bonus_type": "multiplicative"},
        {"id": "prestige_3", "type": "prestige_layer", "name": "Prestige III",
         "formula_expr": "floor(balance_p2_currency / 50)",
         "layer_index": 2,
         "parent_layer": "prestige_2",
         "currency_id": "p3_currency",
         "reset_scope": ["points", "gen_t1", "gen_t2", "gen_t3", "gen_t4",
                         "nested_gen", "upg_x2_t1", "upg_x2_t2", "upg_x3_all",
                         "p1_currency", "p2_currency", "upg_p1_x2"],
         "persistence_scope": ["p3_currency", "sacrifice_pts"],
         "bonus_type": "multiplicative"},

        {"id": "sacrifice", "type": "sacrifice", "name": "Sacrifice",
         "formula_expr": "floor(sqrt(lifetime_points) * 0.1)",
         "reset_scope": ["points", "gen_t1", "gen_t2", "gen_t3", "gen_t4", "nested_gen"],
         "bonus_type": "multiplicative"},

        {"id": "syn_t1_t2", "type": "synergy", "name": "T1-T2 Synergy",
         "sources": ["gen_t1"], "formula_expr": "owned_gen_t1 * 0.02", "target": "gen_t2"},
        {"id": "syn_t3_t4", "type": "synergy", "name": "T3-T4 Synergy",
         "sources": ["gen_t3"], "formula_expr": "owned_gen_t3 * 0.03", "target": "gen_t4"},

        {"id": "gate_p2", "type": "unlock_gate", "name": "Unlock Prestige II",
         "condition_type": "single_threshold",
         "targets": [{"node_id": "p1_currency", "property": "current_value", "threshold": 100.0}],
         "prerequisites": ["prestige_1"]},
        {"id": "gate_p3", "type": "unlock_gate", "name": "Unlock Prestige III",
         "condition_type": "single_threshold",
         "targets": [{"node_id": "p2_currency", "property": "current_value", "threshold": 50.0}],
         "prerequisites": ["prestige_2"]},

        {"id": "ach_100_t1", "type": "achievement", "name": "100 Tier 1 Generators",
         "condition_type": "single_threshold",
         "targets": [{"node_id": "gen_t1", "property": "owned", "threshold": 100}],
         "bonus": {"type": "multiplicative", "magnitude": 3.0, "target": "gen_t1", "stacking_group": "milestones"},
         "permanent": true}
    ],
    "edges": [
        {"id": "e_t1_points", "source": "gen_t1", "target": "points", "edge_type": "production_target"},
        {"id": "e_t2_points", "source": "gen_t2", "target": "points", "edge_type": "production_target"},
        {"id": "e_t3_points", "source": "gen_t3", "target": "points", "edge_type": "production_target"},
        {"id": "e_t4_points", "source": "gen_t4", "target": "points", "edge_type": "production_target"},
        {"id": "e_nested_t1", "source": "nested_gen", "target": "gen_t1", "edge_type": "production_target"},
        {"id": "e_p1_mult", "source": "prestige_1", "target": "gen_t1", "edge_type": "state_modifier",
         "formula": "1 + owned_p1_currency * 0.01",
         "target_property": "base_production", "modifier_mode": "multiply"},
        {"id": "e_p2_add", "source": "prestige_2", "target": "gen_t1", "edge_type": "state_modifier",
         "formula": "owned_p2_currency * 0.5",
         "target_property": "base_production", "modifier_mode": "add"},
        {"id": "e_p3_set", "source": "prestige_3", "target": "gen_t1", "edge_type": "state_modifier",
         "formula": "if(owned_p3_currency > 0, 10.0, 1.0)",
         "target_property": "base_production", "modifier_mode": "set"},
        {"id": "e_gate_p2_dep", "source": "gate_p2", "target": "prestige_2", "edge_type": "unlock_dependency"},
        {"id": "e_gate_p3_dep", "source": "gate_p3", "target": "prestige_3", "edge_type": "unlock_dependency"}
    ]
}
