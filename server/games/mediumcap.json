{
    "schema_version": "1.0",
    "name": "MediumCap",
    "description": "Medium complexity AdCap-like game. 8 generators, 30 upgrades, 2 prestige layers.",
    "stacking_groups": {
        "cash_upgrades": "multiplicative",
        "angel_bonus": "additive",
        "milestones": "multiplicative",
        "mega_upgrades": "multiplicative"
    },
    "nodes": [
        {"id": "cash", "type": "resource", "name": "Cash", "initial_value": 0},
        {"id": "angels", "type": "resource", "name": "Angels", "initial_value": 0},
        {"id": "mega_bucks", "type": "resource", "name": "Mega Bucks", "initial_value": 0},

        {"id": "lemonade", "type": "generator", "name": "Lemonade Stand",
         "base_production": 1.0, "cost_base": 4.0, "cost_growth_rate": 1.07, "cycle_time": 1.0},
        {"id": "newspaper", "type": "generator", "name": "Newspaper Delivery",
         "base_production": 60.0, "cost_base": 60.0, "cost_growth_rate": 1.15, "cycle_time": 3.0},
        {"id": "carwash", "type": "generator", "name": "Car Wash",
         "base_production": 720.0, "cost_base": 720.0, "cost_growth_rate": 1.14, "cycle_time": 6.0},
        {"id": "pizza", "type": "generator", "name": "Pizza Delivery",
         "base_production": 8640.0, "cost_base": 8640.0, "cost_growth_rate": 1.13, "cycle_time": 12.0},
        {"id": "donut", "type": "generator", "name": "Donut Shop",
         "base_production": 103680.0, "cost_base": 103680.0, "cost_growth_rate": 1.12, "cycle_time": 24.0},
        {"id": "shrimp", "type": "generator", "name": "Shrimp Boat",
         "base_production": 1244160.0, "cost_base": 1244160.0, "cost_growth_rate": 1.11, "cycle_time": 48.0},
        {"id": "hockey", "type": "generator", "name": "Hockey Team",
         "base_production": 14929920.0, "cost_base": 14929920.0, "cost_growth_rate": 1.10, "cycle_time": 96.0},
        {"id": "movie", "type": "generator", "name": "Movie Studio",
         "base_production": 179159040.0, "cost_base": 179159040.0, "cost_growth_rate": 1.09, "cycle_time": 192.0},

        {"id": "x3_lemon", "type": "upgrade", "name": "x3 Lemonade",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 1000.0,
         "target": "lemonade", "stacking_group": "cash_upgrades"},
        {"id": "x3_news", "type": "upgrade", "name": "x3 Newspaper",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 5000.0,
         "target": "newspaper", "stacking_group": "cash_upgrades"},
        {"id": "x3_wash", "type": "upgrade", "name": "x3 Car Wash",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 25000.0,
         "target": "carwash", "stacking_group": "cash_upgrades"},
        {"id": "x3_pizza", "type": "upgrade", "name": "x3 Pizza",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 100000.0,
         "target": "pizza", "stacking_group": "cash_upgrades"},
        {"id": "x3_donut", "type": "upgrade", "name": "x3 Donut",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 500000.0,
         "target": "donut", "stacking_group": "cash_upgrades"},
        {"id": "x3_shrimp", "type": "upgrade", "name": "x3 Shrimp",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 2500000.0,
         "target": "shrimp", "stacking_group": "cash_upgrades"},
        {"id": "x3_hockey", "type": "upgrade", "name": "x3 Hockey",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 10000000.0,
         "target": "hockey", "stacking_group": "cash_upgrades"},
        {"id": "x3_movie", "type": "upgrade", "name": "x3 Movie",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 50000000.0,
         "target": "movie", "stacking_group": "cash_upgrades"},

        {"id": "x3_all_1", "type": "upgrade", "name": "x3 All Profit",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 200000.0,
         "target": "_all", "stacking_group": "cash_upgrades"},
        {"id": "x3_all_2", "type": "upgrade", "name": "x3 All Profit II",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 5000000.0,
         "target": "_all", "stacking_group": "cash_upgrades"},
        {"id": "x3_all_3", "type": "upgrade", "name": "x3 All Profit III",
         "upgrade_type": "multiplicative", "magnitude": 3.0, "cost": 100000000.0,
         "target": "_all", "stacking_group": "cash_upgrades"},

        {"id": "angel_x2_lemon", "type": "upgrade", "name": "Angel x2 Lemonade",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 10.0,
         "target": "lemonade", "stacking_group": "cash_upgrades", "tags": ["angel_upgrade"]},
        {"id": "angel_x2_news", "type": "upgrade", "name": "Angel x2 Newspaper",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 25.0,
         "target": "newspaper", "stacking_group": "cash_upgrades", "tags": ["angel_upgrade"]},
        {"id": "angel_x2_wash", "type": "upgrade", "name": "Angel x2 Car Wash",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 50.0,
         "target": "carwash", "stacking_group": "cash_upgrades", "tags": ["angel_upgrade"]},
        {"id": "angel_x2_pizza", "type": "upgrade", "name": "Angel x2 Pizza",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 100.0,
         "target": "pizza", "stacking_group": "cash_upgrades", "tags": ["angel_upgrade"]},
        {"id": "angel_x7_all", "type": "upgrade", "name": "Angel x7.77 All",
         "upgrade_type": "multiplicative", "magnitude": 7.77, "cost": 5000.0,
         "target": "_all", "stacking_group": "cash_upgrades", "tags": ["angel_upgrade"]},

        {"id": "bonus_2pct", "type": "upgrade", "name": "+2% Angel Bonus",
         "upgrade_type": "additive", "magnitude": 0.02, "cost": 50.0,
         "target": "_all", "stacking_group": "angel_bonus", "tags": ["angel_upgrade"]},
        {"id": "bonus_5pct", "type": "upgrade", "name": "+5% Angel Bonus",
         "upgrade_type": "additive", "magnitude": 0.05, "cost": 200.0,
         "target": "_all", "stacking_group": "angel_bonus", "tags": ["angel_upgrade"]},

        {"id": "paid_x10", "type": "upgrade", "name": "x10 All (Paid)",
         "upgrade_type": "multiplicative", "magnitude": 10.0, "cost": 0.0,
         "target": "_all", "stacking_group": "cash_upgrades", "tags": ["paid"]},
        {"id": "paid_x5_pizza", "type": "upgrade", "name": "x5 Pizza (Paid)",
         "upgrade_type": "multiplicative", "magnitude": 5.0, "cost": 0.0,
         "target": "pizza", "stacking_group": "cash_upgrades", "tags": ["paid"]},

        {"id": "dead_upgrade", "type": "upgrade", "name": "Overpriced x1.01",
         "upgrade_type": "multiplicative", "magnitude": 1.01, "cost": 1e15,
         "target": "lemonade", "stacking_group": "cash_upgrades"},

        {"id": "prestige1", "type": "prestige_layer",
         "name": "Angel Investors",
         "formula_expr": "150 * sqrt(lifetime_earnings / 1e15)",
         "layer_index": 0,
         "reset_scope": ["cash", "lemonade", "newspaper", "carwash", "pizza", "donut",
                         "shrimp", "hockey", "movie",
                         "x3_lemon", "x3_news", "x3_wash", "x3_pizza", "x3_donut",
                         "x3_shrimp", "x3_hockey", "x3_movie",
                         "x3_all_1", "x3_all_2", "x3_all_3"],
         "persistence_scope": ["angels", "angel_x2_lemon", "angel_x2_news",
                               "angel_x2_wash", "angel_x2_pizza", "angel_x7_all",
                               "bonus_2pct", "bonus_5pct", "paid_x10", "paid_x5_pizza"],
         "bonus_type": "multiplicative"},

        {"id": "prestige2", "type": "prestige_layer",
         "name": "Mega Investors",
         "formula_expr": "10 * sqrt(total_angels / 1e9)",
         "layer_index": 1,
         "reset_scope": ["cash", "angels", "lemonade", "newspaper", "carwash", "pizza",
                         "donut", "shrimp", "hockey", "movie"],
         "persistence_scope": ["mega_bucks", "paid_x10", "paid_x5_pizza"],
         "bonus_type": "multiplicative"},

        {"id": "milestone_25_lemon", "type": "achievement",
         "name": "25 Lemonade Stands",
         "condition_type": "single_threshold",
         "targets": [{"node_id": "lemonade", "property": "count", "threshold": 25}],
         "logic": "and",
         "bonus": {"type": "multiplicative", "magnitude": 2.0, "target": "lemonade", "stacking_group": "milestones"},
         "permanent": true},

        {"id": "milestone_50_lemon", "type": "achievement",
         "name": "50 Lemonade Stands",
         "condition_type": "single_threshold",
         "targets": [{"node_id": "lemonade", "property": "count", "threshold": 50}],
         "logic": "and",
         "bonus": {"type": "multiplicative", "magnitude": 2.0, "target": "lemonade", "stacking_group": "milestones"},
         "permanent": true},

        {"id": "end", "type": "end_condition",
         "condition_type": "single_threshold",
         "targets": [{"node_id": "cash", "property": "current_value", "threshold": 1e30}],
         "logic": "and"}
    ],
    "edges": [
        {"id": "e_lemon_cash", "source": "lemonade", "target": "cash", "edge_type": "production_target"},
        {"id": "e_news_cash", "source": "newspaper", "target": "cash", "edge_type": "production_target"},
        {"id": "e_wash_cash", "source": "carwash", "target": "cash", "edge_type": "production_target"},
        {"id": "e_pizza_cash", "source": "pizza", "target": "cash", "edge_type": "production_target"},
        {"id": "e_donut_cash", "source": "donut", "target": "cash", "edge_type": "production_target"},
        {"id": "e_shrimp_cash", "source": "shrimp", "target": "cash", "edge_type": "production_target"},
        {"id": "e_hockey_cash", "source": "hockey", "target": "cash", "edge_type": "production_target"},
        {"id": "e_movie_cash", "source": "movie", "target": "cash", "edge_type": "production_target"}
    ]
}
