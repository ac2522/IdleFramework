{
    "schema_version": "1.0",
    "name": "CookieClicker",
    "description": "Classic clicker archetype. 6 generator tiers, upgrades with mult/add stacking, achievements, managers, end condition.",
    "stacking_groups": {
        "click_mult": "multiplicative",
        "flat_bonus": "additive",
        "milestones": "multiplicative"
    },
    "nodes": [
        {"id": "cookies", "type": "resource", "name": "Cookies", "initial_value": 0},

        {"id": "cursor", "type": "generator", "name": "Cursor",
         "base_production": 0.1, "cost_base": 15.0, "cost_growth_rate": 1.15, "cycle_time": 1.0},
        {"id": "grandma", "type": "generator", "name": "Grandma",
         "base_production": 1.0, "cost_base": 100.0, "cost_growth_rate": 1.15, "cycle_time": 1.0},
        {"id": "farm", "type": "generator", "name": "Farm",
         "base_production": 8.0, "cost_base": 1100.0, "cost_growth_rate": 1.15, "cycle_time": 1.0},
        {"id": "mine", "type": "generator", "name": "Mine",
         "base_production": 47.0, "cost_base": 12000.0, "cost_growth_rate": 1.15, "cycle_time": 1.0},
        {"id": "factory", "type": "generator", "name": "Factory",
         "base_production": 260.0, "cost_base": 130000.0, "cost_growth_rate": 1.15, "cycle_time": 1.0},
        {"id": "bank", "type": "generator", "name": "Bank",
         "base_production": 1400.0, "cost_base": 1200000.0, "cost_growth_rate": 1.15, "cycle_time": 1.0},

        {"id": "upg_x2_cursor", "type": "upgrade", "name": "x2 Cursor",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 100.0,
         "target": "cursor", "stacking_group": "click_mult"},
        {"id": "upg_x2_grandma", "type": "upgrade", "name": "x2 Grandma",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 1000.0,
         "target": "grandma", "stacking_group": "click_mult"},
        {"id": "upg_x2_farm", "type": "upgrade", "name": "x2 Farm",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 11000.0,
         "target": "farm", "stacking_group": "click_mult"},
        {"id": "upg_x2_mine", "type": "upgrade", "name": "x2 Mine",
         "upgrade_type": "multiplicative", "magnitude": 2.0, "cost": 120000.0,
         "target": "mine", "stacking_group": "click_mult"},
        {"id": "upg_x5_all", "type": "upgrade", "name": "x5 All",
         "upgrade_type": "multiplicative", "magnitude": 5.0, "cost": 500000.0,
         "target": "_all", "stacking_group": "click_mult"},
        {"id": "upg_plus10_cursor", "type": "upgrade", "name": "+10 Cursor Flat",
         "upgrade_type": "additive", "magnitude": 10.0, "cost": 500.0,
         "target": "cursor", "stacking_group": "flat_bonus"},

        {"id": "ach_10_cursors", "type": "achievement", "name": "10 Cursors",
         "condition_type": "single_threshold",
         "targets": [{"node_id": "cursor", "property": "owned", "threshold": 10}],
         "logic": "and",
         "bonus": {"type": "multiplicative", "magnitude": 2.0, "target": "cursor", "stacking_group": "milestones"},
         "permanent": true},
        {"id": "ach_50_grandmas", "type": "achievement", "name": "50 Grandmas",
         "condition_type": "single_threshold",
         "targets": [{"node_id": "grandma", "property": "owned", "threshold": 50}],
         "logic": "and",
         "bonus": {"type": "multiplicative", "magnitude": 2.0, "target": "grandma", "stacking_group": "milestones"},
         "permanent": true},
        {"id": "ach_100_farms", "type": "achievement", "name": "100 Farms",
         "condition_type": "single_threshold",
         "targets": [{"node_id": "farm", "property": "owned", "threshold": 100}],
         "logic": "and",
         "bonus": {"type": "multiplicative", "magnitude": 2.0, "target": "farm", "stacking_group": "milestones"},
         "permanent": true},

        {"id": "mgr_cursor", "type": "manager", "name": "Cursor Manager",
         "target": "cursor", "automation_type": "collect"},

        {"id": "end_trillion", "type": "end_condition", "name": "Trillion Cookies",
         "condition_type": "single_threshold",
         "targets": [{"node_id": "cookies", "property": "current_value", "threshold": 1e12}],
         "logic": "and"}
    ],
    "edges": [
        {"id": "e_cursor_cookies", "source": "cursor", "target": "cookies", "edge_type": "production_target"},
        {"id": "e_grandma_cookies", "source": "grandma", "target": "cookies", "edge_type": "production_target"},
        {"id": "e_farm_cookies", "source": "farm", "target": "cookies", "edge_type": "production_target"},
        {"id": "e_mine_cookies", "source": "mine", "target": "cookies", "edge_type": "production_target"},
        {"id": "e_factory_cookies", "source": "factory", "target": "cookies", "edge_type": "production_target"},
        {"id": "e_bank_cookies", "source": "bank", "target": "cookies", "edge_type": "production_target"}
    ]
}
